# ChangeImageTo.com — Blogging Agent configuration
# Copy to .env and fill in values for local runs.
# In GitHub Actions, setup_ci.py writes this automatically from repo secrets.

PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

BLOG_NICHE=free online image editing tools
TARGET_AUDIENCE=ecommerce sellers, designers, and content creators
BLOG_TONE=practical, helpful, and SEO-focused
BLOG_LANGUAGE=English

# Reuses SEO agent credentials (same service accounts)
GOOGLE_CREDENTIALS_FILE=google-credentials.json
GSC_SITE_URL=sc-domain:changeimageto.com
GA4_PROPERTY_ID=505035310

# auto = commit HTML directly to main (Vercel auto-deploys)
# pr   = open a GitHub PR for review before publishing
APPROVAL_MODE=auto
PUBLISHER=changeimageto
REPO_DIR=../..
CONTENT_DIR=frontend/blog

CORRECTION_AUTO_MODE=true
MAX_ARTICLES_PER_DAY=1
MIN_QUEUE_SIZE=2
DEDUP_THRESHOLD=0.80
PERFORMANCE_CHECK_DAYS=30
